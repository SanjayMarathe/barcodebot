# Get from https://platform.composio.dev/settings
COMPOSIO_API_KEY=your_composio_api_key

# Run: composio add googlesheets  (connects your Google account)
# Then paste your spreadsheet ID here (leave blank to auto-create)
GOOGLE_SHEETS_SPREADSHEET_ID=

# Usually "default" unless you have multiple Composio users
COMPOSIO_ENTITY_ID=default

SHEETS_AGENT_SEED=sheets-agent-kaimon-2026
SHEETS_AGENT_PORT=8013
