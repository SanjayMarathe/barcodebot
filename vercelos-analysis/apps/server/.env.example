# Voice Vision Server Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# Deepgram API (for real-time transcription)
# Get your API key at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# Anthropic API (for Claude intent analysis)
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# v0 API (for code generation)
# Get your API key at: https://v0.dev/settings
V0_API_KEY=your_v0_api_key

# GitHub Personal Access Token (for repo/PR management)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=your_github_token

# Vercel API Token (optional, for deployment previews)
# Create at: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token
